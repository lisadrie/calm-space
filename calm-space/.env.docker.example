# ============================================================================
#  Exemple de variables d'environnement pour l'environnement Docker.
#  Copiez ce fichier en « .env.docker » et adaptez les valeurs si besoin.
#  (Les valeurs par défaut sont déjà écrites dans docker-compose.yml pour la
#   démonstration — ce fichier documente les secrets à personnaliser.)
# ============================================================================

# Base de données
POSTGRES_USER=postgres
POSTGRES_PASSWORD=calmspace_db_demo
POSTGRES_DB=calmspace

# Backend
PORT=5001
SECRET_KEY=change_me_in_production
CORS_ORIGINS=http://localhost:3000

# Frontend (injecté au build)
REACT_APP_API_URL=http://localhost:5001
